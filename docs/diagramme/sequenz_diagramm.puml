@startumlactor "Sales User" as Userparticipant "Browser" as Browserparticipant "Flask Controller\n(Route /customers/create)" as Controllerparticipant "Service/Model" as Servicedatabase "Store/DB" as DBUser -> Browser: Öffnet Formular\n"Kunde anlegen"Browser -> Controller: GET /customers/createController -> Browser: HTML FormularUser -> Browser: Felder ausfüllen\nund speichernBrowser -> Controller: POST /customers/create (Form Data)Controller -> Controller: Eingaben validierenalt Ungültige Eingaben  Controller -> Browser: HTML Formular + Fehlermeldungenelse Gültige Eingaben  Controller -> Service: createCustomer(data)  Service -> DB: INSERT Customer  DB --> Service: OK + customer_id  Service --> Controller: customer_id  Controller -> Browser: Redirect /customers  Browser -> Controller: GET /customers  Controller -> Service: listCustomers()  Service -> DB: SELECT Customers  DB --> Service: customers[]  Service --> Controller: customers[]  Controller -> Browser: HTML Kundenlisteend@enduml