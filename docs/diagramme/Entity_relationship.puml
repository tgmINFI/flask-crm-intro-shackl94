@startuml' ====== Entities ======entity "Customer" as Customer {  + id : int <<PK>>  --  name : string  email : string  company : string  phone : string  status : string  created_at : datetime}entity "Lead" as Lead {  + id : int <<PK>>  --  name : string  email : string  company : string  value : float  source : string  status : string  created_at : datetime}entity "Contact" as Contact {  + id : int <<PK>>  --  customer_id : int <<FK>>  type : string  notes : text  contact_date : datetime  created_by : int <<FK>>}entity "Task" as Task {  + id : int <<PK>>  --  customer_id : int <<FK>>  title : string  description : text  due_date : date  status : string  ' e.g. open/done  created_at : datetime  created_by : int <<FK>>}entity "Appointment" as Appointment {  + id : int <<PK>>  --  customer_id : int <<FK>>  start_datetime : datetime  end_datetime : datetime  notes : text  created_at : datetime  created_by : int <<FK>>}entity "User" as User {  + id : int <<PK>>  --  username : string  role : string  ' admin/sales  email : string  created_at : datetime}' ====== Relationships (Cardinalities) ======Customer ||--o{ Contact : hasCustomer ||--o{ Task : hasCustomer ||--o{ Appointment : hasUser ||--o{ Contact : createsUser ||--o{ Task : createsUser ||--o{ Appointment : creates@enduml